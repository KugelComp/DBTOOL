# DB Tool — Environment Variables Template
# Copy this file to .env and fill in all values before running.
# NEVER commit the real .env to version control.

# ---------------------------------------------------------------------------
# Application Environment
# ---------------------------------------------------------------------------
APP_ENV=development      # Change to 'production' on server

# ---------------------------------------------------------------------------
# FastAPI Session
# ---------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace-this-with-a-long-random-secret-key-at-least-32-chars
SESSION_TIMEOUT_HOURS=24

# ---------------------------------------------------------------------------
# Django (REQUIRED — app will refuse to start without DJANGO_SECRET_KEY)
# ---------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=replace-with-at-least-50-char-random-secret
DJANGO_DEBUG=false                              # Always false in production!
DJANGO_ALLOWED_HOSTS=yourdomain.com,localhost   # Comma-separated list

# ---------------------------------------------------------------------------
# Default Target Database (used for Obscure/Service-Off exports)
# ---------------------------------------------------------------------------
DEFAULT_TARGET_ENABLED=true
DEFAULT_TARGET_HOST=localhost
DEFAULT_TARGET_PORT=3306
DEFAULT_TARGET_USER=replace-with-db-user
DEFAULT_TARGET_PASSWORD=replace-with-db-password

# ---------------------------------------------------------------------------
# Paths (forward slashes work on all platforms)
# ---------------------------------------------------------------------------
LOG_DIR=logs
DUMP_PATH=dumps
OBSCURE_FILE=obscure.sql
